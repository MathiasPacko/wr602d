{% extends 'base.html.twig' %}

{% block title %}Accueil - PDF Converter{% endblock %}

{% block body %}
<div class="page-header">
    <h1>Bonjour, {{ user.firstname }}</h1>
    <p>Voici un aperçu de votre activité</p>
</div>

<div class="grid grid-3 mb-4">
    <div class="card">
        <div class="flex-between mb-3">
            <span class="text-secondary" style="font-size: 0.8125rem; font-weight: 500;">Abonnement</span>
            <span class="badge {% if plan and plan.name == 'PREMIUM' %}badge-primary{% else %}badge-neutral{% endif %}">
                {{ plan ? plan.name : 'FREE' }}
            </span>
        </div>
        <div style="font-size: 1.75rem; font-weight: 600; letter-spacing: -0.02em; margin-bottom: 4px;">
            {% if is_unlimited %}
                Illimité
            {% else %}
                {{ daily_limit }} <span class="text-secondary" style="font-size: 0.875rem; font-weight: 400;">/ jour</span>
            {% endif %}
        </div>
        <p class="text-tertiary" style="font-size: 0.8125rem;">Conversions disponibles</p>
        <a href="{{ path('app_subscription') }}" class="btn btn-secondary btn-sm mt-3">Gérer</a>
    </div>

    <div class="card">
        <div class="flex-between mb-3">
            <span class="text-secondary" style="font-size: 0.8125rem; font-weight: 500;">Aujourd'hui</span>
            {% if not is_unlimited %}
                <span class="text-tertiary" style="font-size: 0.75rem;">{{ (today_generations / daily_limit * 100)|round }}%</span>
            {% endif %}
        </div>
        <div style="font-size: 2.5rem; font-weight: 600; letter-spacing: -0.02em; margin-bottom: 4px;">
            {{ today_generations }}
            {% if not is_unlimited %}
                <span class="text-tertiary" style="font-size: 1rem; font-weight: 400;">/ {{ daily_limit }}</span>
            {% endif %}
        </div>
        {% if not is_unlimited %}
            <div style="background: var(--bg-tertiary); border-radius: 100px; height: 4px; overflow: hidden; margin-top: 12px;">
                <div style="background: var(--accent); height: 100%; width: {{ (today_generations / daily_limit * 100)|round }}%; transition: width 0.5s ease;"></div>
            </div>
        {% else %}
            <p class="text-tertiary" style="font-size: 0.8125rem;">Conversions effectuées</p>
        {% endif %}
    </div>

    <div class="card">
        <div class="flex-between mb-3">
            <span class="text-secondary" style="font-size: 0.8125rem; font-weight: 500;">Total</span>
        </div>
        <div style="font-size: 2.5rem; font-weight: 600; letter-spacing: -0.02em; margin-bottom: 4px;">
            {{ total_generations }}
        </div>
        <p class="text-tertiary" style="font-size: 0.8125rem;">Conversions depuis le début</p>
        <a href="{{ path('app_history') }}" class="btn btn-secondary btn-sm mt-3">Historique</a>
    </div>
</div>

<div class="flex-between mb-2">
    <h2 style="font-size: 1.125rem; font-weight: 600; letter-spacing: -0.01em;">Actions rapides</h2>
</div>

<div class="grid grid-4">
    <a href="{{ path('app_convert_url') }}" class="card card-hoverable" style="text-decoration: none;">
        <div class="card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
            </svg>
        </div>
        <h3 class="card-title">URL vers PDF</h3>
        <p class="card-description">Convertir une page web</p>
    </a>

    <a href="{{ path('app_convert_html') }}" class="card card-hoverable" style="text-decoration: none;">
        <div class="card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <polyline points="16 18 22 12 16 6"/>
                <polyline points="8 6 2 12 8 18"/>
            </svg>
        </div>
        <h3 class="card-title">HTML vers PDF</h3>
        <p class="card-description">Convertir du code HTML</p>
    </a>

    <a href="{{ path('app_convert_office') }}" class="card card-hoverable" style="text-decoration: none;">
        <div class="card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
            </svg>
        </div>
        <h3 class="card-title">Office vers PDF</h3>
        <p class="card-description">Word, Excel, PowerPoint</p>
    </a>

    <a href="{{ path('app_contacts') }}" class="card card-hoverable" style="text-decoration: none;">
        <div class="card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
        </div>
        <h3 class="card-title">Contacts</h3>
        <p class="card-description">Gérer vos destinataires</p>
    </a>
</div>
{% endblock %}
