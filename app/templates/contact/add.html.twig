{% extends 'base.html.twig' %}

{% block title %}Ajouter un contact - PDF Converter{% endblock %}

{% block body %}
<div class="page-header">
    <h1>Ajouter un contact</h1>
    <p>Ajoutez un nouveau destinataire pour vos partages de PDF</p>
</div>

<div class="card" style="max-width: 520px;">
    <div class="flex gap-2 items-center mb-3" style="padding-bottom: 20px; border-bottom: 1px solid var(--border-subtle);">
        <div class="card-icon" style="margin-bottom: 0;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="8.5" cy="7" r="4"/>
                <line x1="20" y1="8" x2="20" y2="14"/>
                <line x1="23" y1="11" x2="17" y2="11"/>
            </svg>
        </div>
        <div>
            <h3 style="font-size: 0.9375rem; font-weight: 600; margin-bottom: 2px;">Nouveau contact</h3>
            <p class="text-tertiary" style="font-size: 0.8125rem;">Remplissez les informations du contact</p>
        </div>
    </div>

    {{ form_start(form, {'attr': {'data-turbo': 'false'}}) }}
        <div class="form-group">
            {{ form_label(form.firstname) }}
            {{ form_widget(form.firstname) }}
            {{ form_errors(form.firstname) }}
        </div>

        <div class="form-group">
            {{ form_label(form.lastname) }}
            {{ form_widget(form.lastname) }}
            {{ form_errors(form.lastname) }}
        </div>

        <div class="form-group">
            {{ form_label(form.email) }}
            {{ form_widget(form.email) }}
            {{ form_errors(form.email) }}
        </div>

        <div class="flex gap-1 mt-3">
            {{ form_widget(form.submit) }}
            <a href="{{ path('app_contacts') }}" class="btn btn-secondary">Annuler</a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
