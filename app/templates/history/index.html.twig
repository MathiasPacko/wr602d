{% extends 'base.html.twig' %}

{% block title %}Historique - PDF Converter{% endblock %}

{% block body %}
<h1>Historique des conversions</h1>

{% if generations|length > 0 %}
    <div class="card">
        <table class="table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Fichier</th>
                    <th>Type</th>
                </tr>
            </thead>
            <tbody>
                {% for generation in generations %}
                <tr>
                    <td>{{ generation.createdAt|date('d/m/Y H:i') }}</td>
                    <td>{{ generation.file }}</td>
                    <td>
                        {% if 'url_' in generation.file %}
                            <span class="badge badge-info">URL</span>
                        {% elseif 'html_' in generation.file %}
                            <span class="badge badge-success">HTML</span>
                        {% elseif 'office_' in generation.file %}
                            <span class="badge badge-warning">Office</span>
                        {% else %}
                            <span class="badge badge-secondary">Autre</span>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% else %}
    <div class="card text-center" style="padding: 3rem;">
        <div style="font-size: 4rem; margin-bottom: 1rem;">📋</div>
        <h3>Aucune conversion</h3>
        <p class="text-muted">Vous n'avez pas encore effectué de conversion.</p>
        <a href="{{ path('app_pdf_index') }}" class="btn btn-primary mt-2">Faire une conversion</a>
    </div>
{% endif %}
{% endblock %}
