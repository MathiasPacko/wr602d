{% extends 'base.html.twig' %}

{% block title %}Acces refuse - PDF Converter{% endblock %}

{% block body %}
<div style="max-width: 600px; margin: 60px auto; text-align: center;">
    <div class="card" style="padding: 48px 40px;">
        <div style="width: 80px; height: 80px; margin: 0 auto 24px; background: var(--danger-subtle); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--danger)" stroke-width="1.5">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
        </div>

        <h1 style="font-size: 1.75rem; font-weight: 600; margin-bottom: 12px;">Acces refuse</h1>
        <p class="text-secondary" style="font-size: 1rem; margin-bottom: 32px; line-height: 1.6;">
            {{ exception.message|default('Cette fonctionnalite n\'est pas incluse dans votre abonnement actuel.') }}
        </p>

        {% if app.user %}
            <div style="background: var(--bg-tertiary); border-radius: var(--radius-md); padding: 20px; margin-bottom: 32px;">
                <div class="flex-between" style="margin-bottom: 12px;">
                    <span class="text-secondary" style="font-size: 0.875rem;">Votre abonnement actuel</span>
                    <span class="badge {% if app.user.plan and app.user.plan.name == 'PREMIUM' %}badge-primary{% elseif app.user.plan and app.user.plan.name == 'BASIC' %}badge-success{% else %}badge-neutral{% endif %}">
                        {{ app.user.plan ? app.user.plan.name : 'FREE' }}
                    </span>
                </div>
                <p class="text-tertiary" style="font-size: 0.8125rem; margin: 0;">
                    {% if app.user.plan %}
                        {{ app.user.plan.description|default('Plan actuel') }}
                    {% else %}
                        Plan gratuit avec fonctionnalites limitees
                    {% endif %}
                </p>
            </div>
        {% endif %}

        <div class="flex gap-1" style="justify-content: center;">
            <a href="{{ path('app_subscription') }}" class="btn btn-primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
                Mettre a niveau
            </a>
            <a href="{{ path('app_pdf_index') }}" class="btn btn-secondary">
                Retour aux outils
            </a>
        </div>
    </div>

    <div class="card mt-3" style="padding: 20px;">
        <h3 style="font-size: 0.9375rem; font-weight: 600; margin-bottom: 16px;">Comparer les plans</h3>
        <div class="grid grid-3" style="gap: 12px; text-align: left;">
            <div style="padding: 12px; background: var(--bg-tertiary); border-radius: var(--radius-sm);">
                <div class="flex-between mb-1">
                    <span style="font-weight: 600; font-size: 0.875rem;">FREE</span>
                    <span class="text-tertiary" style="font-size: 0.75rem;">0 EUR</span>
                </div>
                <p class="text-tertiary" style="font-size: 0.75rem; margin: 0;">URL, HTML</p>
            </div>
            <div style="padding: 12px; background: var(--bg-tertiary); border-radius: var(--radius-sm);">
                <div class="flex-between mb-1">
                    <span style="font-weight: 600; font-size: 0.875rem;">BASIC</span>
                    <span class="text-tertiary" style="font-size: 0.75rem;">9.99 EUR</span>
                </div>
                <p class="text-tertiary" style="font-size: 0.75rem; margin: 0;">+ Office, Markdown</p>
            </div>
            <div style="padding: 12px; background: var(--accent-subtle); border-radius: var(--radius-sm); border: 1px solid var(--accent);">
                <div class="flex-between mb-1">
                    <span style="font-weight: 600; font-size: 0.875rem; color: var(--accent);">PREMIUM</span>
                    <span class="text-tertiary" style="font-size: 0.75rem;">29.99 EUR</span>
                </div>
                <p class="text-tertiary" style="font-size: 0.75rem; margin: 0;">Tous les outils</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
