{% extends 'base.html.twig' %}

{% block title %}Convertir - PDF Converter{% endblock %}

{% block body %}
<h1>Convertir en PDF</h1>

<div class="card" style="margin-bottom: 2rem;">
    <h3 class="card-title">Statut du service Gotenberg</h3>
    {% if gotenberg_status %}
        <span class="badge badge-success">En ligne</span>
    {% else %}
        <span class="badge" style="background: #e74c3c; color: white;">Hors ligne</span>
    {% endif %}
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
    <div class="card">
        <h3 class="card-title">URL vers PDF</h3>
        <p class="text-muted mb-2">Convertissez n'importe quelle page web en document PDF.</p>
        <a href="{{ path('app_pdf_convert_url') }}" class="btn btn-primary">Convertir une URL</a>
    </div>

    <div class="card">
        <h3 class="card-title">HTML vers PDF</h3>
        <p class="text-muted mb-2">Convertissez du code HTML personnalisé en document PDF.</p>
        <a href="{{ path('app_pdf_convert_html') }}" class="btn btn-primary">Convertir du HTML</a>
    </div>

    <div class="card">
        <h3 class="card-title">Office vers PDF</h3>
        <p class="text-muted mb-2">Convertissez vos fichiers Word, Excel ou PowerPoint.</p>
        <a href="{{ path('app_pdf_convert_office') }}" class="btn btn-primary">Convertir un fichier</a>
    </div>
</div>
{% endblock %}
